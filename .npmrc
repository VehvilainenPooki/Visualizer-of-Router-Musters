# Supply Chain Attack Protections

# Require packages to be at least 7 days old before installing
min-release-age=7

# Use the official npm registry (prevent registry hijacking)
registry=https://registry.npmjs.org/

# Enforce exact versions on npm install (no surprise updates)
save-exact=true

# Verify integrity of packages against their lockfile
package-lock=true

# Fail on audit findings of high severity or above during install
audit-level=high

# Prevent scripts from running during install unless explicitly needed
ignore-scripts=true

# Enforce SSL strictly
strict-ssl=true

# Suppress funding prompts
fund=false
