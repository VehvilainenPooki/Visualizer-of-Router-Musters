{
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",
    "rootDir": ".",
    "outDir": "build",
    "composite": true,
    "skipLibCheck": true
  },
  "exclude": [
    "node_modules"
  ],
  "references": [
    { "path": "./src/server" },
    { "path": "./src/client" }
  ]
}
